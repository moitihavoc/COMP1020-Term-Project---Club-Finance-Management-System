<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.SVGPath?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="oop.mony.controllers.RegisterController"
           style="-fx-background-color: #F5F5F0;">

    <VBox alignment="CENTER" spacing="32" maxWidth="400">

        <Label text="Mony"
               style="-fx-font-size: 48px; -fx-font-weight: 800; -fx-text-fill: #191919;"/>

        <Label text="Create your account"
               style="-fx-font-size: 16px; -fx-text-fill: #888888;"/>

        <VBox spacing="16" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 40;">

            <VBox spacing="6">
                <Label text="Username"
                       style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                <TextField fx:id="usernameField" promptText="Enter username"
                           style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Password"
                       style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <StackPane HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <PasswordField fx:id="passwordField" promptText="Enter password"
                                       maxWidth="Infinity"
                                       style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
                        <TextField fx:id="visiblePasswordField" promptText="Enter password"
                                   managed="false" visible="false" maxWidth="Infinity"
                                   style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
                    </StackPane>
                    <Button fx:id="togglePasswordButton"
                            onAction="#handleTogglePasswordVisibility"
                            prefWidth="42" prefHeight="40"
                            focusTraversable="false"
                            style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;">
                        <graphic>
                            <SVGPath fx:id="passwordVisibilityIcon" fill="#666666" content="M12 4.5 C7 4.5 2.73 7.61 1 12 C2.73 16.39 7 19.5 12 19.5 C17 19.5 21.27 16.39 23 12 C21.27 7.61 17 4.5 12 4.5 Z M12 16 C9.79 16 8 14.21 8 12 C8 9.79 9.79 8 12 8 C14.21 8 16 9.79 16 12 C16 14.21 14.21 16 12 16 Z M12 14 C13.1 14 14 13.1 14 12 C14 10.9 13.1 10 12 10 C10.9 10 10 10.9 10 12 C10 13.1 10.9 14 12 14 Z"/>
                        </graphic>
                    </Button>
                </HBox>
            </VBox>

            <VBox spacing="6">
                <Label text="Confirm Password"
                       style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <StackPane HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <PasswordField fx:id="confirmPasswordField" promptText="Confirm password"
                                       maxWidth="Infinity"
                                       style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
                        <TextField fx:id="visibleConfirmPasswordField" promptText="Confirm password"
                                   managed="false" visible="false" maxWidth="Infinity"
                                   style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
                    </StackPane>
                    <Button fx:id="toggleConfirmPasswordButton"
                            onAction="#handleToggleConfirmPasswordVisibility"
                            prefWidth="42" prefHeight="40"
                            focusTraversable="false"
                            style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;">
                        <graphic>
                            <SVGPath fx:id="confirmPasswordVisibilityIcon" fill="#666666" content="M12 4.5 C7 4.5 2.73 7.61 1 12 C2.73 16.39 7 19.5 12 19.5 C17 19.5 21.27 16.39 23 12 C21.27 7.61 17 4.5 12 4.5 Z M12 16 C9.79 16 8 14.21 8 12 C8 9.79 9.79 8 12 8 C14.21 8 16 9.79 16 12 C16 14.21 14.21 16 12 16 Z M12 14 C13.1 14 14 13.1 14 12 C14 10.9 13.1 10 12 10 C10.9 10 10 10.9 10 12 C10 13.1 10.9 14 12 14 Z"/>
                        </graphic>
                    </Button>
                </HBox>
            </VBox>

            <!-- Error / Success area with min height so layout doesn't shift -->
            <VBox minHeight="20">
                <Label fx:id="errorLabel" text=""
                       style="-fx-text-fill: #e53935; -fx-font-size: 13px;"/>
                <Label fx:id="successLabel" text=""
                       style="-fx-text-fill: #299D91; -fx-font-size: 13px;"/>
            </VBox>

            <Button fx:id="registerButton" text="Register"
                    onAction="#handleRegister"
                    maxWidth="400"
                    defaultButton="true"
                    style="-fx-background-color: #299D91; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: 700; -fx-padding: 12 0 12 0; -fx-background-radius: 8;"/>

            <Button text="Back to Login"
                    onAction="#handleBackToLogin"
                    maxWidth="400"
                    style="-fx-background-color: transparent; -fx-text-fill: #299D91; -fx-font-size: 14px; -fx-padding: 8 0 8 0; -fx-border-color: #299D91; -fx-border-radius: 8; -fx-background-radius: 8;"/>

        </VBox>
    </VBox>
</StackPane>
