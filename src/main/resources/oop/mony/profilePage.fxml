<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="oop.mony.controllers.ProfileController"
      prefWidth="1440" prefHeight="1024">

    <!-- SIDEBAR -->
    <VBox prefWidth="280" prefHeight="1024"
          style="-fx-background-color: #191919; -fx-padding: 48 28 48 28; -fx-min-width: 280; -fx-max-width: 280;">

        <Label text="Mony"
               style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: 800;"/>

        <VBox spacing="4" style="-fx-padding: 40 0 0 0;">
            <HBox spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleGoToProjects"
                  style="-fx-padding: 12 16 12 16; -fx-background-radius: 4; -fx-cursor: hand;">
                <Label text="Projects"
                       style="-fx-text-fill: #aaaaaa; -fx-font-size: 15px;"/>
            </HBox>
            <HBox spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleGoToTransactions"
                  style="-fx-padding: 12 16 12 16; -fx-background-radius: 4; -fx-cursor: hand;">
                <Label text="Transactions"
                       style="-fx-text-fill: #aaaaaa; -fx-font-size: 15px;"/>
            </HBox>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <!-- VIEW PROFILE (active) -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              onMouseClicked="#handleViewProfile"
              style="-fx-border-color: #333333; -fx-border-width: 1 0 0 0; -fx-padding: 20 0 12 0; -fx-cursor: hand;">
            <VBox spacing="2">
                <Label fx:id="sidebarUsername" text="User"
                       style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 600;"/>
                <Label text="View profile"
                       style="-fx-text-fill: #299D91; -fx-font-size: 12px;"/>
            </VBox>
        </HBox>

        <!-- LOGOUT -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              onMouseClicked="#handleLogout"
              style="-fx-padding: 12 0 0 0; -fx-cursor: hand;">
            <Label fx:id="logoutButton" text="Logout"
                   style="-fx-text-fill: #e53935; -fx-font-size: 14px; -fx-font-weight: 600;"/>
        </HBox>
    </VBox>

    <!-- MAIN CONTENT -->
    <VBox prefWidth="1160" prefHeight="1024" style="-fx-background-color: #f8f8f6;">

        <!-- TOP BAR -->
        <HBox alignment="CENTER_LEFT" prefHeight="70"
              style="-fx-background-color: white; -fx-padding: 0 32 0 32; -fx-border-color: #eeeeee; -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="Hello,"
                       style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                <Label fx:id="usernameLabel" text=""
                       style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
            </HBox>
        </HBox>

        <!-- PAGE CONTENT -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="24" style="-fx-padding: 32;">

                <Label text="Profile"
                       style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>

                <!-- PROFILE INFO CARD -->
                <VBox spacing="20" prefWidth="480"
                      style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 28 28 28 28;">

                    <VBox spacing="4">
                        <Label text="Username"
                               style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                        <Label fx:id="profileUsernameLabel" text=""
                               style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Password"
                               style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                        <Label text="••••••••"
                               style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                    </VBox>

                    <Label text="Change Password"
                           onMouseClicked="#handleChangePassword"
                           style="-fx-text-fill: #299D91; -fx-font-size: 14px; -fx-font-weight: 600; -fx-cursor: hand;"/>
                </VBox>

                <!-- CHANGE PASSWORD FORM (hidden by default) -->
                <VBox fx:id="changePasswordForm" spacing="16" prefWidth="480"
                      managed="false" visible="false"
                      style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 28 28 28 28;">

                    <Label text="Change Password"
                           style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>

                    <VBox spacing="6">
                        <Label text="Current Password"
                               style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                        <PasswordField fx:id="currentPasswordField" promptText="Enter current password"
                                       style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="New Password"
                               style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                        <PasswordField fx:id="newPasswordField" promptText="Enter new password"
                                       style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Confirm New Password"
                               style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                        <PasswordField fx:id="confirmNewPasswordField" promptText="Confirm new password"
                                       style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
                    </VBox>

                    <Label fx:id="changePasswordErrorLabel" text=""
                           style="-fx-text-fill: #e53935; -fx-font-size: 13px;"/>

                    <HBox spacing="12">
                        <Button text="Update Password" onAction="#handleConfirmChangePassword"
                                style="-fx-background-color: #299D91; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 600; -fx-padding: 10 24 10 24; -fx-background-radius: 8;"/>
                        <Button text="Cancel" onAction="#handleCancelChangePassword"
                                style="-fx-background-color: transparent; -fx-border-color: #cccccc; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 14px; -fx-padding: 10 24 10 24;"/>
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>
</HBox>
