<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="oop.mony.controllers.ProjectPageController">

    <!-- SIDEBAR -->
    <VBox prefWidth="280"
          style="-fx-background-color: #191919; -fx-padding: 48 28 48 28; -fx-min-width: 280; -fx-max-width: 280;">

        <Label text="Mony"
               style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: 800;"/>

        <VBox spacing="4" style="-fx-padding: 40 0 0 0;">
            <HBox spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleGoToProjects"
                  style="-fx-background-color: #299D91; -fx-padding: 12 16 12 16; -fx-background-radius: 4; -fx-cursor: hand;">
                <Label text="Projects"
                       style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 600;"/>
            </HBox>

            <!-- Sub-item: current project -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: #2a2a2a; -fx-padding: 10 16 10 32; -fx-background-radius: 4;">
                <Label fx:id="sidebarProjectNameLabel" text=""
                       style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleGoToTransactions"
                  style="-fx-padding: 12 16 12 16; -fx-background-radius: 4; -fx-cursor: hand;">
                <Label text="Transactions"
                       style="-fx-text-fill: #aaaaaa; -fx-font-size: 15px;"/>
            </HBox>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <!-- ACCOUNT SETTINGS -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              onMouseClicked="#handleViewProfile"
              style="-fx-border-color: #333333; -fx-border-width: 1 0 0 0; -fx-padding: 20 0 12 0; -fx-cursor: hand;">
            <VBox spacing="2">
                <Label fx:id="sidebarUsername" text="User"
                       style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 600;"/>
                <Label text="Change password"
                       style="-fx-text-fill: #666666; -fx-font-size: 12px;"/>
            </VBox>
        </HBox>

        <!-- LOGOUT -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              onMouseClicked="#handleLogout"
              style="-fx-padding: 12 0 0 0; -fx-cursor: hand;">
            <Label fx:id="logoutButton" text="Logout"
                   style="-fx-text-fill: #e53935; -fx-font-size: 14px; -fx-font-weight: 600;"/>
        </HBox>
    </VBox>

    <!-- MAIN CONTENT -->
    <VBox HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: #f8f8f6;">

        <!-- PAGE CONTENT -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="24" style="-fx-padding: 32;">

                <!-- PAGE HEADER -->
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <VBox spacing="8">
                        <Label fx:id="projectNameLabel" text="Project"
                               style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                        <Label text="Track pots, spending, and remaining allocation"
                               style="-fx-font-size: 15px; -fx-text-fill: #878787;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="editMenuBtn" text="Edit" onAction="#handleEditMenu"
                            style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px; -fx-padding: 6 14 6 14; -fx-cursor: hand;"/>
                    <Button text="Back to Projects" onAction="#handleGoToProjects"
                            style="-fx-background-color: transparent; -fx-border-color: #cccccc; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px; -fx-padding: 6 14 6 14; -fx-cursor: hand;"/>
                </HBox>

                <!-- STATS ROW -->
                <HBox spacing="20">
                    <VBox spacing="6" prefWidth="280"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20 24 20 24;">
                        <Label text="Allocated"
                               style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                        <Label fx:id="allocatedAmountLabel" text="0"
                               style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                    </VBox>
                    <VBox spacing="6" prefWidth="280"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20 24 20 24;">
                        <Label text="Spent"
                               style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                        <Label fx:id="totalSpentLabel" text="0"
                               style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                    </VBox>
                    <VBox spacing="6" prefWidth="280"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20 24 20 24;">
                        <Label text="Remaining"
                               style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                        <Label fx:id="totalRemainingLabel" text="0"
                               style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                    </VBox>
                </HBox>


                <!-- POTS SECTION -->
                <VBox spacing="16">
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label text="Pots"
                               style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                        <Button text="+ Create Pot" onAction="#handleCreatePot"
                                style="-fx-background-color: #299D91; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 8 16 8 16; -fx-background-radius: 8;"/>
                    </HBox>

                    <!-- CREATE POT FORM (hidden by default) -->
                    <VBox fx:id="createPotForm" spacing="12" managed="false" visible="false"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 24; -fx-max-width: 480;">
                        <Label text="New Pot"
                               style="-fx-font-size: 16px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                        <VBox spacing="6">
                            <Label text="Pot Name"
                                   style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                            <TextField fx:id="newPotNameField" promptText="e.g. Food, Operations"
                                       style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
                        </VBox>
                        <VBox spacing="6">
                            <Label text="Allocated Amount"
                                   style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                            <TextField fx:id="newPotAllocatedField" promptText="0"
                                       style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
                        </VBox>
                        <Label fx:id="createPotErrorLabel" text=""
                               style="-fx-text-fill: #e53935; -fx-font-size: 13px;"/>
                        <HBox spacing="12">
                            <Button text="Create" onAction="#handleConfirmCreatePot"
                                    style="-fx-background-color: #299D91; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 600; -fx-padding: 10 24 10 24; -fx-background-radius: 8;"/>
                            <Button text="Cancel" onAction="#handleCancelCreatePot"
                                    style="-fx-background-color: transparent; -fx-border-color: #cccccc; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 14px; -fx-padding: 10 24 10 24;"/>
                        </HBox>
                    </VBox>

                    <FlowPane fx:id="potsGrid" hgap="16" vgap="16" prefWrapLength="1060"/>
                </VBox>

                <!-- TRANSACTIONS SECTION -->
                <VBox spacing="16">
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label text="Transactions"
                               style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                        <Button text="+ Record Transaction" onAction="#handleCreateTransaction"
                                style="-fx-background-color: #299D91; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 8 16 8 16; -fx-background-radius: 8;"/>
                    </HBox>

                    <!-- RECORD TRANSACTION FORM (hidden by default) -->
                    <VBox fx:id="createTransactionForm" spacing="12" managed="false" visible="false"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 24; -fx-max-width: 560;">
                        <Label text="Record Transaction"
                               style="-fx-font-size: 16px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                        <HBox spacing="16">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Transaction Name"
                                       style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                                <TextField fx:id="transactionNameField" promptText="Enter name"
                                           style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Pot"
                                       style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                                <ComboBox fx:id="potComboBox" promptText="Select pot"
                                          maxWidth="Infinity"
                                          style="-fx-font-size: 14px; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
                            </VBox>
                        </HBox>
                        <HBox spacing="16">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Amount"
                                       style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                                <TextField fx:id="transactionAmountField" promptText="0"
                                           style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Paid By"
                                       style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                                <TextField fx:id="paidByField" promptText="Enter name"
                                           style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
                            </VBox>
                        </HBox>
                        <HBox spacing="16">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Date"
                                       style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                                <DatePicker fx:id="transactionDatePicker"
                                            maxWidth="Infinity"
                                            style="-fx-font-size: 14px; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Proof Image"
                                       style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                                <Button fx:id="proofUploadButton" text="Upload File"
                                        onAction="#handleProofUpload"
                                        maxWidth="Infinity"
                                        style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-cursor: hand;"/>
                            </VBox>
                        </HBox>
                        <VBox spacing="6">
                            <Label text="Note"
                                   style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                            <TextField fx:id="noteField" promptText="Optional note"
                                       style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
                        </VBox>
                        <Label fx:id="createTransactionErrorLabel" text=""
                               style="-fx-text-fill: #e53935; -fx-font-size: 13px;"/>
                        <HBox spacing="12">
                            <Button text="Record" onAction="#handleConfirmCreateTransaction"
                                    style="-fx-background-color: #299D91; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 600; -fx-padding: 10 24 10 24; -fx-background-radius: 8;"/>
                            <Button text="Cancel" onAction="#handleCancelCreateTransaction"
                                    style="-fx-background-color: transparent; -fx-border-color: #cccccc; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 14px; -fx-padding: 10 24 10 24;"/>
                        </HBox>
                    </VBox>

                    <!-- TRANSACTION TABLE -->
                    <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 0;">

                        <!-- TABLE HEADER -->
                        <GridPane hgap="12"
                                  style="-fx-padding: 14 20 14 20; -fx-border-color: #eeeeee; -fx-border-width: 0 0 1 0;">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="16"/>
                                <ColumnConstraints percentWidth="22"/>
                                <ColumnConstraints percentWidth="14"/>
                                <ColumnConstraints percentWidth="14"/>
                                <ColumnConstraints percentWidth="14"/>
                                <ColumnConstraints percentWidth="12"/>
                                <ColumnConstraints percentWidth="8"/>
                            </columnConstraints>
                            <Label text="Date" GridPane.columnIndex="0"
                                   style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
                            <Label text="Transaction Name" GridPane.columnIndex="1"
                                   style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
                            <Label text="Pot" GridPane.columnIndex="2"
                                   style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
                            <Label text="Paid By" GridPane.columnIndex="3"
                                   style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
                            <Label text="Note" GridPane.columnIndex="4"
                                   style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
                            <Label text="Amount" GridPane.columnIndex="5"
                                   style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
                            <Label text="Proof" GridPane.columnIndex="6"
                                   style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
                        </GridPane>

                        <!-- DYNAMIC ROWS -->
                        <VBox fx:id="transactionsContainer" spacing="0"/>
                    </VBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>
</HBox>
