<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="oop.mony.controllers.ProjectTransactionSectionController"
      spacing="16">
    <Label text="Transactions"
           style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
    <Button text="+ Record Transaction" onAction="#handleCreateTransaction"
            style="-fx-background-color: #299D91; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 8 16 8 16; -fx-background-radius: 8;"/>

    <VBox fx:id="createTransactionForm" spacing="12" managed="false" visible="false"
          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 24; -fx-max-width: 560;">
        <Label text="Record Transaction"
               style="-fx-font-size: 16px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
        <HBox spacing="16">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Transaction Name"
                       style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                <TextField fx:id="transactionNameField" promptText="Enter name"
                           style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Pot"
                       style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                <ComboBox fx:id="potComboBox" promptText="Select pot"
                          maxWidth="Infinity"
                          style="-fx-font-size: 14px; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
            </VBox>
        </HBox>
        <HBox spacing="16">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Amount"
                       style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                <TextField fx:id="transactionAmountField" promptText="0"
                           style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Paid By"
                       style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                <TextField fx:id="paidByField" promptText="Enter name"
                           style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
            </VBox>
        </HBox>
        <HBox spacing="16">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Date"
                       style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                <DatePicker fx:id="transactionDatePicker"
                            maxWidth="Infinity"
                            style="-fx-font-size: 14px; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Proof Image"
                       style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                <Button fx:id="proofUploadButton" text="Upload File"
                        onAction="#handleProofUpload"
                        maxWidth="Infinity"
                        style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-cursor: hand;"/>
            </VBox>
        </HBox>
        <VBox spacing="6">
            <Label text="Note"
                   style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
            <TextField fx:id="noteField" promptText="Optional note"
                       style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
        </VBox>
        <Label fx:id="createTransactionErrorLabel" text=""
               style="-fx-text-fill: #e53935; -fx-font-size: 13px;"/>
        <HBox spacing="12">
            <Button text="Record" onAction="#handleConfirmCreateTransaction"
                    style="-fx-background-color: #299D91; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 600; -fx-padding: 10 24 10 24; -fx-background-radius: 8;"/>
            <Button text="Cancel" onAction="#handleCancelCreateTransaction"
                    style="-fx-background-color: transparent; -fx-border-color: #cccccc; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 14px; -fx-padding: 10 24 10 24;"/>
        </HBox>
    </VBox>

    <VBox spacing="0"
          style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 24 28 28 28; -fx-effect: dropshadow(gaussian, rgba(76,103,100,0.10), 25, 0, 0, 8);">
        <GridPane hgap="12"
                  style="-fx-padding: 0 20 14 20; -fx-border-color: #eeeeee; -fx-border-width: 0 0 1 0;">
            <columnConstraints>
                <ColumnConstraints percentWidth="11"/>
                <ColumnConstraints percentWidth="18"/>
                <ColumnConstraints percentWidth="11"/>
                <ColumnConstraints percentWidth="10"/>
                <ColumnConstraints percentWidth="12"/>
                <ColumnConstraints percentWidth="14"/>
                <ColumnConstraints percentWidth="14"/>
                <ColumnConstraints percentWidth="10"/>
            </columnConstraints>
            <Label text="Date" GridPane.columnIndex="0"
                   style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
            <Label text="Transaction Name" GridPane.columnIndex="1"
                   style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
            <Label text="Project" GridPane.columnIndex="2"
                   style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
            <Label text="Pot" GridPane.columnIndex="3"
                   style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
            <Label text="Paid By" GridPane.columnIndex="4"
                   style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
            <Label text="Amount" GridPane.columnIndex="5"
                   style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
            <Label text="Note" GridPane.columnIndex="6"
                   style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
            <Label text="Proof" GridPane.columnIndex="7"
                   style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
        </GridPane>

        <VBox fx:id="transactionsContainer" spacing="0"/>
    </VBox>
</VBox>
