<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="oop.mony.controllers.ProjectController">

    <!-- SIDEBAR -->
    <VBox fx:id="sidebar"
          style="-fx-background-color: #191919; -fx-padding: 48 28 48 28;">

        <Label text="Mony"
               style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: 800;"/>

        <VBox spacing="4" style="-fx-padding: 40 0 0 0;">
            <HBox spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleGoToDashboard"
                  style="-fx-background-color: #299D91; -fx-padding: 12 16 12 16; -fx-background-radius: 4; -fx-cursor: hand;">
                <Label text="Dashboard"
                       style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 600;"/>
            </HBox>

            <!-- Sub-item: current project -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: #2a2a2a; -fx-padding: 10 16 10 32; -fx-background-radius: 4;">
                <Label fx:id="sidebarProjectNameLabel" text=""
                       style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleGoToTransactions"
                  style="-fx-padding: 12 16 12 16; -fx-background-radius: 4; -fx-cursor: hand;">
                <Label text="Transactions"
                       style="-fx-text-fill: #aaaaaa; -fx-font-size: 15px;"/>
            </HBox>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <!-- ACCOUNT SETTINGS -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              onMouseClicked="#handleChangePassword"
              style="-fx-border-color: #333333; -fx-border-width: 1 0 0 0; -fx-padding: 20 0 12 0; -fx-cursor: hand;">
            <VBox spacing="2">
                <Label fx:id="sidebarUsername" text="User"
                       style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 600;"/>
                <Label text="Change password"
                       style="-fx-text-fill: #666666; -fx-font-size: 12px;"/>
            </VBox>
        </HBox>

        <!-- LOGOUT -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              onMouseClicked="#handleLogout"
              style="-fx-padding: 12 0 0 0; -fx-cursor: hand;">
            <Label fx:id="logoutButton" text="Logout"
                   style="-fx-text-fill: #e53935; -fx-font-size: 14px; -fx-font-weight: 600;"/>
        </HBox>
    </VBox>

    <!-- MAIN CONTENT -->
    <VBox HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: #f8f8f6;">

        <!-- PAGE CONTENT -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="24" style="-fx-padding: 32;">

                <!-- PAGE HEADER -->
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <VBox spacing="8">
                        <Label fx:id="projectNameLabel" text="Project"
                               style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                        <Label text="View project finance and manage pots, transactions"
                               style="-fx-font-size: 15px; -fx-text-fill: #878787;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="editMenuBtn" text="Edit" onAction="#handleEditMenu"
                            style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px; -fx-padding: 6 14 6 14; -fx-cursor: hand;"/>
                    <Button text="Delete" onAction="#handleDeleteProject"
                            style="-fx-background-color: #ffebee; -fx-text-fill: #e53935; -fx-background-radius: 8; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 6 14 6 14; -fx-cursor: hand;"/>
                    <Button text="Back to Dashboard" onAction="#handleGoToDashboard"
                            style="-fx-background-color: transparent; -fx-border-color: #cccccc; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px; -fx-padding: 6 14 6 14; -fx-cursor: hand;"/>
                </HBox>

                <!-- STATS ROW -->
                <HBox spacing="20">
                    <VBox spacing="6" prefWidth="280"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20 24 20 24;">
                        <Label text="Allocated"
                               style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                        <Label fx:id="allocatedAmountLabel" text="0"
                               style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                    </VBox>
                    <VBox spacing="6" prefWidth="280"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20 24 20 24;">
                        <Label text="Spent"
                               style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                        <Label fx:id="totalSpentLabel" text="0"
                               style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                    </VBox>
                    <VBox spacing="6" prefWidth="280"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20 24 20 24;">
                        <Label text="Remaining"
                               style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                        <Label fx:id="totalRemainingLabel" text="0"
                               style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                    </VBox>
                </HBox>


                <fx:include fx:id="potsSection" source="projectPotSection.fxml"/>

                <fx:include fx:id="transactionsSection" source="projectTransactionSection.fxml"/>

            </VBox>
        </ScrollPane>
    </VBox>
</HBox>
