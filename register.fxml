<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.demo.RegisterController"
           prefWidth="1440" prefHeight="1024"
           style="-fx-background-color: #F5F5F0;">

    <VBox alignment="CENTER" spacing="32" maxWidth="400">

        <Label text="Mony"
               style="-fx-font-size: 48px; -fx-font-weight: 800; -fx-text-fill: #191919;"/>

        <Label text="Create your account"
               style="-fx-font-size: 16px; -fx-text-fill: #888888;"/>

        <VBox spacing="16" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 40;">

            <VBox spacing="6">
                <Label text="Username" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                <TextField fx:id="usernameField" promptText="Enter username"
                           style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Email (Gmail)" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                <TextField fx:id="emailField" promptText="Enter Gmail address"
                           style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Password" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                <PasswordField fx:id="passwordField" promptText="Enter password"
                               style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Confirm Password" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #191919;"/>
                <PasswordField fx:id="confirmPasswordField" promptText="Confirm password"
                               style="-fx-font-size: 14px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0;"/>
            </VBox>

            <Label fx:id="errorLabel" text=""
                   style="-fx-text-fill: #e53935; -fx-font-size: 13px;"/>

            <Button fx:id="registerButton" text="Register"
                    onAction="#handleRegister"
                    maxWidth="400"
                    style="-fx-background-color: #299D91; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: 700; -fx-padding: 12 0 12 0; -fx-background-radius: 8;"/>

            <Button text="Back to Login"
                    onAction="#handleBackToLogin"
                    maxWidth="400"
                    style="-fx-background-color: transparent; -fx-text-fill: #299D91; -fx-font-size: 14px; -fx-padding: 8 0 8 0; -fx-border-color: #299D91; -fx-border-radius: 8; -fx-background-radius: 8;"/>

        </VBox>
    </VBox>
</StackPane>