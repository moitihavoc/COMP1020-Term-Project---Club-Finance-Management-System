<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="oop.mony.mony.controllers.ProjectPageController"
      prefWidth="1440" prefHeight="1024">

    <!-- SIDEBAR -->
    <VBox prefWidth="280" prefHeight="1024"
          style="-fx-background-color: #191919; -fx-padding: 48 28 48 28; -fx-min-width: 280; -fx-max-width: 280;">

        <Label text="Mony"
               style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: 800;"/>

        <VBox spacing="4" style="-fx-padding: 40 0 0 0;">
            <HBox spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleGoToProjects"
                  style="-fx-background-color: #299D91; -fx-padding: 12 16 12 16; -fx-background-radius: 4; -fx-cursor: hand;">
                <Label text="Projects"
                       style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 600;"/>
            </HBox>

            <!-- Sub-item: current project name, indented under Projects -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: #2a2a2a; -fx-padding: 12 16 12 32; -fx-background-radius: 4;">
                <Label fx:id="sidebarProjectNameLabel" text=""
                       style="-fx-text-fill: #aaaaaa; -fx-font-size: 15px;"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleGoToTransactions"
                  style="-fx-padding: 12 16 12 16; -fx-background-radius: 4; -fx-cursor: hand;">
                <Label text="Transactions"
                       style="-fx-text-fill: #aaaaaa; -fx-font-size: 15px;"/>
            </HBox>
        </VBox>



        <Region VBox.vgrow="ALWAYS"/>

        <HBox spacing="12" alignment="CENTER_LEFT"
              onMouseClicked="#handleViewProfile"
              style="-fx-border-color: #333333; -fx-border-width: 1 0 0 0; -fx-padding: 20 0 0 0; -fx-cursor: hand;">
            <VBox spacing="2">
                <Label fx:id="sidebarUsername" text="User"
                       style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 600;"/>
                <Label text="View profile"
                       style="-fx-text-fill: #666666; -fx-font-size: 12px;"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- MAIN CONTENT -->
    <VBox prefWidth="1160" prefHeight="1024" style="-fx-background-color: #f8f8f6;">

        <!-- TOP BAR -->
        <HBox alignment="CENTER_LEFT" prefHeight="70"
              style="-fx-background-color: white; -fx-padding: 0 32 0 32; -fx-border-color: #eeeeee; -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="Hello"
                       style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                <Label fx:id="usernameLabel" text=""
                       style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="16" alignment="CENTER">
                <Label text="&#128276;" style="-fx-font-size: 18px; -fx-text-fill: #555555;"/>
                <TextField promptText="Search here..." prefWidth="200" prefHeight="34"
                           style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0; -fx-font-size: 13px; -fx-padding: 0 10 0 10;"/>
            </HBox>
        </HBox>

        <!-- PAGE CONTENT -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="24" style="-fx-padding: 32;">

                <!-- STATS ROW -->
                <HBox spacing="20">
                    <VBox spacing="6" prefWidth="280"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20 24 20 24;">
                        <Label text="Total Balance"
                               style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                        <Label fx:id="totalBalanceLabel" text="\$0"
                               style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                    </VBox>
                    <VBox spacing="6" prefWidth="280"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20 24 20 24;">
                        <Label text="Total Spent"
                               style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                        <Label fx:id="totalSpentLabel" text="\$0"
                               style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                    </VBox>
                    <VBox spacing="6" prefWidth="280"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20 24 20 24;">
                        <Label text="Total Remaining"
                               style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                        <Label fx:id="totalRemainingLabel" text="\$0"
                               style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                    </VBox>
                </HBox>

                <!-- PROJECT TITLE + EDIT -->
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <Label fx:id="projectNameLabel" text="Project"
                           style="-fx-font-size: 22px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                    <Button fx:id="editMenuBtn" text="Edit" onAction="#handleEditMenu"
                            style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px; -fx-padding: 6 14 6 14; -fx-cursor: hand;"/>
                    <Button text="&#8592; Back to Projects" onAction="#handleGoToProjects"
                            style="-fx-background-color: transparent; -fx-border-color: #cccccc; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px; -fx-padding: 6 14 6 14; -fx-cursor: hand;"/>
                </HBox>

                <!-- BUDGET POTS SECTION -->
                <VBox spacing="16">
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label text="Budget Pots"
                               style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                        <Button text="+ Create Pot" onAction="#handleCreatePot"
                                style="-fx-background-color: #299D91; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 8 16 8 16; -fx-background-radius: 8;"/>
                    </HBox>
                    <FlowPane fx:id="potsGrid" hgap="16" vgap="16" prefWrapLength="1060"/>
                </VBox>

                <!-- TRANSACTIONS SECTION -->
                <VBox spacing="16">
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label text="Transactions"
                               style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                        <Button text="+ Record Transaction" onAction="#handleCreateTransaction"
                                style="-fx-background-color: #299D91; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 8 16 8 16; -fx-background-radius: 8;"/>
                    </HBox>
                    <VBox fx:id="transactionsContainer" spacing="10"
                          style="-fx-background-color: white; -fx-background-radius: 12;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>
</HBox>
