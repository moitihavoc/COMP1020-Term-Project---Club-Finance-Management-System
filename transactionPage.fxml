<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.demo.TransactionPageController"
      prefWidth="1440" prefHeight="1024">

    <!-- SIDEBAR -->
    <VBox prefWidth="280" prefHeight="1024"
          style="-fx-background-color: #191919; -fx-padding: 48 28 48 28; -fx-min-width: 280; -fx-max-width: 280;">

        <Label text="Mony"
               style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: 800;"/>

        <VBox spacing="4" style="-fx-padding: 40 0 0 0;">
            <HBox spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleGoToProjects"
                  style="-fx-padding: 12 16 12 16; -fx-background-radius: 4; -fx-cursor: hand;">
                <Label text="Projects"
                       style="-fx-text-fill: #aaaaaa; -fx-font-size: 15px;"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: #299D91; -fx-padding: 12 16 12 16; -fx-background-radius: 4;">
                <Label text="Transactions"
                       style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 600;"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleBackToProjectDetail"
                  style="-fx-padding: 12 16 12 16; -fx-background-radius: 4; -fx-cursor: hand;">
                <Label text="Project Detail"
                       style="-fx-text-fill: #aaaaaa; -fx-font-size: 15px;"/>
            </HBox>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <HBox spacing="12" alignment="CENTER_LEFT"
              onMouseClicked="#handleViewProfile"
              style="-fx-border-color: #333333; -fx-border-width: 1 0 0 0; -fx-padding: 20 0 0 0; -fx-cursor: hand;">
            <VBox spacing="2">
                <Label fx:id="sidebarUsername" text="User"
                       style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 600;"/>
                <Label text="View profile"
                       style="-fx-text-fill: #666666; -fx-font-size: 12px;"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- MAIN -->
    <VBox prefWidth="1160" prefHeight="1024" style="-fx-background-color: #f8f8f6;">

        <!-- TOP HEADER -->
        <HBox alignment="CENTER_LEFT" prefHeight="70"
              style="-fx-background-color: white; -fx-padding: 0 32 0 32; -fx-border-color: #eeeeee; -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="Hello"
                       style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                <Label fx:id="usernameLabel" text=""
                       style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <TextField fx:id="searchField"
                       promptText="Search here"
                       prefWidth="280"
                       style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #eeeeee; -fx-border-radius: 12; -fx-padding: 10 16 10 16; -fx-font-size: 14px;"/>
        </HBox>

        <!-- CONTENT -->
        <VBox spacing="20" style="-fx-padding: 32;">

            <!-- TITLE + BUTTON -->
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="4">
                    <Label fx:id="projectNameLabel" text="All Transactions"
                           style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #191919;"/>
                    <Label text="Manage all income and expense records"
                           style="-fx-font-size: 14px; -fx-text-fill: #878787;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Button fx:id="recordTransactionButton"
                        text="+ Record Transaction"
                        onAction="#handleRecordTransaction"
                        style="-fx-background-color: #299D91; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 700; -fx-padding: 10 20 10 20; -fx-background-radius: 8;"/>
            </HBox>

            <!-- FILTER TABS -->
            <HBox spacing="20">
                <Button fx:id="allTabButton"
                        text="All"
                        onAction="#handleShowAllTransactions"
                        style="-fx-background-color: transparent; -fx-text-fill: #299D91; -fx-font-size: 16px; -fx-font-weight: 700; -fx-border-color: #299D91; -fx-border-width: 0 0 2 0;"/>

                <Button fx:id="incomeTabButton"
                        text="Income"
                        onAction="#handleShowIncomeTransactions"
                        style="-fx-background-color: transparent; -fx-text-fill: #525256; -fx-font-size: 16px; -fx-font-weight: 700;"/>

                <Button fx:id="expenseTabButton"
                        text="Expenses"
                        onAction="#handleShowExpenseTransactions"
                        style="-fx-background-color: transparent; -fx-text-fill: #525256; -fx-font-size: 16px; -fx-font-weight: 700;"/>
            </HBox>

            <!-- TABLE CARD -->
            <VBox spacing="0"
                  style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 24 28 28 28; -fx-effect: dropshadow(gaussian, rgba(76,103,100,0.10), 25, 0, 0, 8);">

                <!-- TABLE HEADER -->
                <GridPane hgap="16"
                          style="-fx-padding: 0 0 14 0; -fx-border-color: #eeeeee; -fx-border-width: 0 0 1 0;">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="6"/>
                        <ColumnConstraints percentWidth="22"/>
                        <ColumnConstraints percentWidth="15"/>
                        <ColumnConstraints percentWidth="14"/>
                        <ColumnConstraints percentWidth="16"/>
                        <ColumnConstraints percentWidth="17"/>
                        <ColumnConstraints percentWidth="10"/>
                    </columnConstraints>

                    <Label text="NO." GridPane.columnIndex="0"
                           style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
                    <Label text="Note" GridPane.columnIndex="1"
                           style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
                    <Label text="Project" GridPane.columnIndex="2"
                           style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
                    <Label text="Pot" GridPane.columnIndex="3"
                           style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
                    <Label text="Date" GridPane.columnIndex="4"
                           style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
                    <Label text="Payment Method" GridPane.columnIndex="5"
                           style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
                    <Label text="Amount" GridPane.columnIndex="6"
                           style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #9f9f9f;"/>
                </GridPane>

                <!-- DYNAMIC ROW CONTAINER -->
                <VBox fx:id="transactionsTableBody" spacing="0">

                    <!-- SAMPLE ROW 1 -->
                    <GridPane hgap="16"
                              style="-fx-padding: 16 0 16 0; -fx-border-color: #f0f0f0; -fx-border-width: 0 0 1 0;">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="6"/>
                            <ColumnConstraints percentWidth="22"/>
                            <ColumnConstraints percentWidth="15"/>
                            <ColumnConstraints percentWidth="14"/>
                            <ColumnConstraints percentWidth="16"/>
                            <ColumnConstraints percentWidth="17"/>
                            <ColumnConstraints percentWidth="10"/>
                        </columnConstraints>

                        <Label text="1" GridPane.columnIndex="0" style="-fx-font-size: 14px; -fx-text-fill: #525256;"/>
                        <Label text="Tea Break" GridPane.columnIndex="1" style="-fx-font-size: 14px; -fx-text-fill: #191919; -fx-font-weight: 600;"/>
                        <Label text="Project 1" GridPane.columnIndex="2" style="-fx-font-size: 14px; -fx-text-fill: #525256;"/>
                        <Label text="Event" GridPane.columnIndex="3" style="-fx-font-size: 14px; -fx-text-fill: #525256;"/>
                        <Label text="January 10, 2026" GridPane.columnIndex="4" style="-fx-font-size: 14px; -fx-text-fill: #525256;"/>
                        <Label text="Cash" GridPane.columnIndex="5" style="-fx-font-size: 14px; -fx-text-fill: #525256;"/>
                        <Label text="-$500,000" GridPane.columnIndex="6" style="-fx-font-size: 14px; -fx-text-fill: #e73d1c; -fx-font-weight: 700;"/>
                    </GridPane>

                    <!-- SAMPLE ROW 2 -->
                    <GridPane hgap="16"
                              style="-fx-padding: 16 0 16 0; -fx-border-color: #f0f0f0; -fx-border-width: 0 0 1 0;">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="6"/>
                            <ColumnConstraints percentWidth="22"/>
                            <ColumnConstraints percentWidth="15"/>
                            <ColumnConstraints percentWidth="14"/>
                            <ColumnConstraints percentWidth="16"/>
                            <ColumnConstraints percentWidth="17"/>
                            <ColumnConstraints percentWidth="10"/>
                        </columnConstraints>

                        <Label text="2" GridPane.columnIndex="0" style="-fx-font-size: 14px; -fx-text-fill: #525256;"/>
                        <Label text="Facebook Ads" GridPane.columnIndex="1" style="-fx-font-size: 14px; -fx-text-fill: #191919; -fx-font-weight: 600;"/>
                        <Label text="Project 1" GridPane.columnIndex="2" style="-fx-font-size: 14px; -fx-text-fill: #525256;"/>
                        <Label text="Marketing" GridPane.columnIndex="3" style="-fx-font-size: 14px; -fx-text-fill: #525256;"/>
                        <Label text="January 9, 2026" GridPane.columnIndex="4" style="-fx-font-size: 14px; -fx-text-fill: #525256;"/>
                        <Label text="Online Transfer" GridPane.columnIndex="5" style="-fx-font-size: 14px; -fx-text-fill: #525256;"/>
                        <Label text="-$670,000" GridPane.columnIndex="6" style="-fx-font-size: 14px; -fx-text-fill: #e73d1c; -fx-font-weight: 700;"/>
                    </GridPane>

                    <!-- SAMPLE ROW 3 -->
                    <GridPane hgap="16"
                              style="-fx-padding: 16 0 16 0;">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="6"/>
                            <ColumnConstraints percentWidth="22"/>
                            <ColumnConstraints percentWidth="15"/>
                            <ColumnConstraints percentWidth="14"/>
                            <ColumnConstraints percentWidth="16"/>
                            <ColumnConstraints percentWidth="17"/>
                            <ColumnConstraints percentWidth="10"/>
                        </columnConstraints>

                        <Label text="3" GridPane.columnIndex="0" style="-fx-font-size: 14px; -fx-text-fill: #525256;"/>
                        <Label text="Sponsor Income" GridPane.columnIndex="1" style="-fx-font-size: 14px; -fx-text-fill: #191919; -fx-font-weight: 600;"/>
                        <Label text="Project 2" GridPane.columnIndex="2" style="-fx-font-size: 14px; -fx-text-fill: #525256;"/>
                        <Label text="Funding" GridPane.columnIndex="3" style="-fx-font-size: 14px; -fx-text-fill: #525256;"/>
                        <Label text="January 8, 2026" GridPane.columnIndex="4" style="-fx-font-size: 14px; -fx-text-fill: #525256;"/>
                        <Label text="Bank Transfer" GridPane.columnIndex="5" style="-fx-font-size: 14px; -fx-text-fill: #525256;"/>
                        <Label text="+$5,000,000" GridPane.columnIndex="6" style="-fx-font-size: 14px; -fx-text-fill: #4daf6e; -fx-font-weight: 700;"/>
                    </GridPane>

                </VBox>
            </VBox>
        </VBox>
    </VBox>
</HBox>
